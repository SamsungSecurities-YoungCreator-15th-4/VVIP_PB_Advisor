# backend 환경변수 템플릿 (커밋 대상)
# 실제 값은 backend/.env 에 넣고 절대 커밋하지 않는다. 이 파일은 플레이스홀더만 유지한다.

# --- Supabase 접근 (방식 A: supabase-py 클라이언트) ---
# RPC 호출 전용 (pgvector match_document_chunks 등)
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role: RLS 우회 슈퍼유저 수준. 백엔드 런타임(RPC·쿼리)과 시드 스크립트(Admin API)에 필요.
# 최소권한 원칙상 이상적으로는 세분화(런타임=제한 롤, 시드=service_role)가 바람직하나,
# MVP 단계에서는 백엔드가 코드 레벨로 pb_id 필터를 직접 적용(2차 방어선)해 보완한다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# JWT 로컬 검증용 시크릿 — Dashboard → Settings → API → JWT Secret
# 설정 시 매 요청마다 네트워크 왕복 없이 로컬 검증. 미설정 시 supabase.auth.get_user() 폴백.
SUPABASE_JWT_SECRET=your-jwt-secret-here

# --- PostgreSQL 직접 연결 (방식 B: psycopg3) ---
# 복잡한 조회·조인용. Supabase 대시보드 → Settings → Database → Connection string → URI
# 주의: 아래 3종 중 환경에 맞는 것 하나를 선택해 붙일 것.
#   - Direct (포트 5432): 로컬 개발·상주 서버. IPv4 직접연결 제약 가능성 있음.
#   - Session pooler (포트 5432, pooler 호스트): 상주 서버에 안전한 기본 선택.
#   - Transaction pooler (포트 6543): 서버리스/단기 연결용. 상주 FastAPI엔 비권장.
# 형식: postgresql://postgres.[ref]:[PASSWORD]@[host]:[port]/postgres
DATABASE_URL=postgresql://postgres.your-ref:your-password@your-host:5432/postgres

# --- Azure OpenAI 공용 리소스 (임베딩 + IPS 추출이 같은 엔드포인트·키 사용) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here

# 임베딩 (RAG): 배포명 ai-insight-embedding = text-embedding-3-small (1536차원)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=ai-insight-embedding
AZURE_OPENAI_EMBEDDING_API_VERSION=2023-05-15

# IPS 추출 (STT 후처리)
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT=your-azure-openai-deployment-here
AZURE_OPENAI_TIMEOUT_SECONDS=60

# --- LLM 생성 (gpt-4o · 검색형 AI 인사이트 answer 생성용) ---
# 위 IPS 추출용 AZURE_OPENAI_DEPLOYMENT 와는 별개 배포다.
# Azure 배포명 ai-insight-llm = gpt-4o, API 버전 2025-01-01-preview.
AZURE_OPENAI_LLM_DEPLOYMENT=ai-insight-llm
AZURE_OPENAI_LLM_API_VERSION=2025-01-01-preview

# --- LLM 요약 (검색형 AI 인사이트 summary 생성용) ---
# POST /rag/insight 의 answer 를 IPS Unique 반영용 30~50자 명사형 문구로 압축한다.
# 모델명이 아니라 실제 Azure '배포명'을 넣는다(모델명을 넣으면 404 DeploymentNotFound 로
# 요약이 항상 폴백된다). 전용 배포가 없으면 IPS 추출용 AZURE_OPENAI_DEPLOYMENT 또는
# answer 생성용 AZURE_OPENAI_LLM_DEPLOYMENT 와 같은 배포를 재사용해도 된다.
AZURE_OPENAI_INSIGHT_SUMMARY_DEPLOYMENT=pb-json-extractor
AZURE_OPENAI_INSIGHT_SUMMARY_API_VERSION=2025-01-01-preview
# (대안 후보) Google AI Studio — 현재 미사용.
# GOOGLE_AI_STUDIO_API_KEY=your-google-ai-studio-key-here

# --- Azure Speech STT ---
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=your-azure-speech-region-here
SPEECH_TRANSCRIPTION_TIMEOUT_SECONDS=300

# --- DART Open API (회사코드 적재 scripts/ingest_corp_code.py 전용) ---
# https://opendart.fss.or.kr 에서 발급. 로컬 적재 스크립트에서만 쓰고 런타임은 미사용.
DART_API_KEY=your-dart-open-api-key-here

# --- Frontend CORS ---
# 쉼표로 여러 origin 입력 가능.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://vvip-pb-advisor.vercel.app
