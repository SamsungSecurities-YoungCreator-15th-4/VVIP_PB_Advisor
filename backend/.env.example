# backend 환경변수 템플릿 (커밋 대상)
# 실제 값은 backend/.env 에 넣고 절대 커밋하지 않는다. 이 파일은 플레이스홀더만 유지한다.

# --- Supabase 접근 (방식 A: supabase-py 클라이언트) ---
# RPC 호출 전용 (pgvector match_document_chunks 등)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- PostgreSQL 직접 연결 (방식 B: psycopg3) ---
# 복잡한 조회·조인용. Supabase 대시보드 → Settings → Database → Connection string → URI
# 주의: 아래 3종 중 환경에 맞는 것 하나를 선택해 붙일 것.
#   - Direct (포트 5432): 로컬 개발·상주 서버. IPv4 직접연결 제약 가능성 있음.
#   - Session pooler (포트 5432, pooler 호스트): 상주 서버에 안전한 기본 선택.
#   - Transaction pooler (포트 6543): 서버리스/단기 연결용. 상주 FastAPI엔 비권장.
# 형식: postgresql://postgres.[ref]:[PASSWORD]@[host]:[port]/postgres
DATABASE_URL=postgresql://postgres.your-ref:your-password@your-host:5432/postgres

# --- OpenAI (임베딩 전용) ---
# text-embedding-3-small (1536차원)
OPENAI_API_KEY=your-openai-api-key-here

# --- LLM 생성 (6/14 회의 후 확정 시 활성화) ---
# 우측 AI 인사이트 answer 생성용. 현재 미확정이라 주석 처리.
# GOOGLE_AI_STUDIO_API_KEY=your-google-ai-studio-key-here

# --- Azure Speech STT ---
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=your-azure-speech-region-here

# --- Azure OpenAI IPS 추출 ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=your-azure-openai-deployment-here

# --- Frontend CORS ---
# 쉼표로 여러 origin 입력 가능.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
