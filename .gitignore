# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---------- Node / Next.js (frontend) ----------
# 모노레포 구조이므로 루트 기준이 아닌 임의 깊이에서 매칭되도록 한다.
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production build
build/

# typescript
*.tsbuildinfo
next-env.d.ts

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# ---------- Python (backend) ----------
__pycache__/
*.pyc
venv/
.venv/
*.egg-info/
.pytest_cache/
# RAG 데이터·인덱스 (용량 큰 파일)
# PDF는 용량이 커서 git 제외 (드라이브/슬랙으로 공유), 하위 폴더까지 매칭
backend/data/**/*.pdf
backend/data/*.docx
backend/faiss_index/
*.index

# ---------- 고객/상담 민감 데이터 (PII 유출 방지) ----------
# 실제 VVIP 상담 전사·음성 등은 추적 금지. .txt/.json/음성 파일은 무시한다.
# 이미 커밋된 STT 테스트 샘플은 추적 상태가 유지되며 영향받지 않는다.
backend/data/*.txt
backend/data/*.json
backend/app/stt/.env
# 공유용 더미/샘플은 파일명에 "sample" 을 넣으면 예외로 추적된다 (실데이터엔 절대 사용 금지).
# 그 외 의도적 추가는 `git add -f <파일>` 로 강제 추가.
!**/*sample*

# ---------- 환경 변수 ----------
# .env 류는 모두 무시하되, 템플릿인 .env.example만 추적한다.
.env
.env.*
!.env.example
backend/.env

# ---------- OS / Editor ----------
.DS_Store
*.pem
.idea/
# .vscode/는 일단 무시한다. 팀이 공유 설정(권장 익스텐션·디버그 설정 등)을 도입하면
# 아래 .vscode/ 줄을 제거하거나, 추적할 파일만 별도로 화이트리스트(!.vscode/extensions.json 등) 처리한다.
.vscode/

# ---------- AI 코딩 도구 ----------
# Claude Code
.claude/
# MCP 서버 설정(개인 로컬 설정). project_ref만 담기지만 팀 공유 대신 각자 관리한다.
.mcp.json

# ---------- STT 개발 관련 ----------
.env
venv/
__pycache__/
*.wav
*.mp3
