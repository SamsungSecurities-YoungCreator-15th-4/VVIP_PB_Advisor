# frontend 환경변수 템플릿 (커밋 대상)
# 실제 값은 frontend/.env.local 에 넣고 절대 커밋하지 않는다. 이 파일은 플레이스홀더만 유지한다.
# Next.js는 브라우저 노출 변수에 NEXT_PUBLIC_ 접두사 필수.
# anon 키는 공개 전제 키라 NEXT_PUBLIC_ OK. service_role은 절대 프론트에 두지 마.

# --- Supabase (프론트: anon 키만) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- 백엔드 API 주소 ---
# Vercel Production은 Render 백엔드 주소를 단일 값으로 설정한다.
# 로컬 개발 시에는 frontend/.env.local 에서 http://localhost:8000 로 바꿔 쓴다.
# 쉼표로 여러 주소를 넣으면 fetch base URL이 깨진다.
NEXT_PUBLIC_API_BASE_URL=https://vvip-pb-advisor.onrender.com
